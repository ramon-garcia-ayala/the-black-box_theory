{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.mjs": {
      "includeFiles": "{Slides_Datasets,assets/PDF}/**"
    }
  },
  "headers": [
    {
      "source": "/api/slides",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    }
  ]
}
